{
  "name": "@stato/angular",
  "version": "0.1.0",
  "private": false,
  "description": "Stato — Angular adapter with native Signals",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test":  "vitest run",
    "dev":   "tsup --watch"
  },
  "peerDependencies": {
    "@angular/core": ">=17.0.0"
  },
  "dependencies": {
    "@stato/core": "workspace:*"
  },
  "devDependencies": {
    "tsup":       "^8.0.0",
    "vitest":     "^1.6.0",
    "typescript": "^5.4.0",
    "@angular/core": "^17.0.0"
  }
}